<UserControl x:Class="PolarToCartesianInterpolator.WpfDemo.Controls.CartesianHeatMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="300"
             MinWidth="300">
    <Grid Background="#111827">
        <Border Margin="8" BorderThickness="1" BorderBrush="#374151" Background="#0B1220">
            <Grid>
                <Image x:Name="HeatMapImage"
                       Stretch="Fill"
                       SnapsToDevicePixels="True"
                       UseLayoutRounding="True" />

                <Line X1="0" Y1="0.5" X2="1" Y2="0.5"
                      Stretch="Fill"
                      Stroke="#66FFFFFF"
                      StrokeThickness="1" />
                <Line X1="0.5" Y1="0" X2="0.5" Y2="1"
                      Stretch="Fill"
                      Stroke="#66FFFFFF"
                      StrokeThickness="1" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
