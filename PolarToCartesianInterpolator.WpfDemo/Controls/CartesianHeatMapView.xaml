<UserControl x:Class="PolarToCartesianInterpolator.WpfDemo.Controls.CartesianHeatMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="360"
             MinWidth="560">
    <Grid Background="White" Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="130" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <Canvas x:Name="YAxisCanvas"
                Grid.Column="0"
                Grid.Row="0"
                Background="White" />

        <Border Grid.Column="1"
                Grid.Row="0"
                BorderThickness="1"
                BorderBrush="#D1D5DB"
                Background="White">
            <Grid x:Name="HeatMapViewport">
                <Image x:Name="HeatMapImage"
                       Stretch="Fill"
                       SnapsToDevicePixels="True"
                       UseLayoutRounding="True" />
                <Canvas x:Name="OverlayCanvas"
                        IsHitTestVisible="False"
                        ClipToBounds="True"
                        Background="Transparent" />
            </Grid>
        </Border>

        <Canvas x:Name="XAxisCanvas"
                Grid.Column="1"
                Grid.Row="1"
                Background="White" />

        <Border Grid.Column="2"
                Grid.Row="0"
                Grid.RowSpan="2"
                Margin="12,0,0,0"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                Background="White"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Temperature"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <Grid Grid.Row="1" Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            CornerRadius="2"
                            BorderBrush="#9CA3AF"
                            BorderThickness="1">
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#FFFF0000" Offset="0.0" />
                                    <GradientStop Color="#FFFFA500" Offset="0.25" />
                                    <GradientStop Color="#FFFFFF00" Offset="0.50" />
                                    <GradientStop Color="#FF008000" Offset="0.75" />
                                    <GradientStop Color="#FF0000FF" Offset="1.0" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Border>
                    <Canvas x:Name="LegendCanvas"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Background="White" />
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Red = 1.0, Blue = 0.0"
                           FontSize="11"
                           Foreground="#374151"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
