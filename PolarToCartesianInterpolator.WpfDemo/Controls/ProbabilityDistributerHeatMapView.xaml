<UserControl x:Class="PolarToCartesianInterpolator.WpfDemo.Controls.ProbabilityDistributerHeatMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PolarToCartesianInterpolator.WpfDemo.Controls"
             MinHeight="420"
             MinWidth="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="8"
                BorderBrush="#D1D5DB"
                BorderThickness="1"
                Background="White"
                Padding="10">
            <StackPanel>
                <TextBlock Text="Probability Distributer"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />

                <TextBlock Text="R50" FontWeight="SemiBold" />
                <TextBox x:Name="R50TextBox"
                         Margin="0,6,0,10"
                         Text="0"
                         LostFocus="R50TextBox_OnLostFocus" />

                <TextBlock Text="Target Probability"
                           FontWeight="SemiBold" />
                <ComboBox x:Name="TargetProbabilityComboBox"
                          Margin="0,6,0,10"
                          SelectionChanged="TargetProbabilityComboBox_OnSelectionChanged">
                    <ComboBoxItem Content="0.95" IsSelected="True" />
                    <ComboBoxItem Content="0.99" />
                    <ComboBoxItem Content="0.999" />
                </ComboBox>

                <TextBlock x:Name="SigmaTextBlock"
                           Margin="0,8,0,4"
                           Foreground="#374151" />
                <TextBlock x:Name="KernelTextBlock"
                           Margin="0,0,0,4"
                           Foreground="#374151" />
                <TextBlock Text="R50 = 0 iken filtre uygulanmaz."
                           FontSize="11"
                           Foreground="#6B7280"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <controls:CartesianHeatMapView x:Name="HeatMapView"
                                       Grid.Column="1"
                                       GridData="{Binding DisplayGrid, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Cutoff="{Binding Cutoff, RelativeSource={RelativeSource AncestorType=UserControl}}" />
    </Grid>
</UserControl>
